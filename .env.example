# ============================================================
#  DHFC-EBiS — Modèle de variables d'environnement
#  Copier vers `.env.local` et renseigner les valeurs réelles.
#  NE JAMAIS committer `.env.local` (secrets).
# ============================================================

# --- Base de données PostgreSQL (Neon recommandé) ---
# Connexion poolée (pgbouncer) pour le runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
# Connexion directe (non poolée) pour les migrations Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Authentification (Auth.js / NextAuth) ---
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="" # openssl rand -base64 32
