// ============================================================
//  DHFC-EBiS — Schéma Prisma (socle)
//  Modèles alignés sur l'application actuelle (vitrine + LMS apprenant).
//  D'autres modules du cahier (§8 : forums, messagerie, banque
//  d'exercices, médias…) seront ajoutés au fil des chantiers.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  APPRENANT
  TUTEUR
  ENCADREUR
  CONCEPTEUR
  ADMIN
  SUPERADMIN
}

enum Level {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
}

enum LessonType {
  VIDEO
  TEXTE
  QUIZ
}

model Discipline {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  short     String
  color     String
  bivalence String
  icon      String // clé d'icône (mappée vers un composant côté UI)
  parcours  Parcours[]
  createdAt DateTime   @default(now())
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  firstName    String
  lastName     String
  role         Role             @default(APPRENANT)
  bivalence    String?
  region       String?
  dren         String?
  college      String?
  xp           Int              @default(0)
  level        Int              @default(1)
  streak       Int              @default(0)
  active       Boolean          @default(true)
  passwordHash String?
  enrollments    Enrollment[]
  progress       LessonProgress[]
  badges         UserBadge[]
  certificates   Certificate[]
  tutoredCohorts Cohort[]         @relation("TutorCohorts")
  submissions    Submission[]     @relation("UserSubmissions")
  gradedSubmissions Submission[]  @relation("GradedSubmissions")
  forumThreads   ForumThread[]    @relation("ForumThreads")
  forumPosts     ForumPost[]      @relation("ForumPosts")
  conversations  ConversationParticipant[]
  sentMessages   Message[]        @relation("SentMessages")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Parcours {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  subtitle      String
  description   String
  disciplineId  String
  discipline    Discipline   @relation(fields: [disciplineId], references: [id])
  level         Level
  durationHours Int
  ratingAvg     Float        @default(0)
  reviewsCount  Int          @default(0)
  enrolledCount Int          @default(0)
  isNew         Boolean      @default(false)
  published     Boolean      @default(true)
  coverUrl      String?
  objectives    String[]
  prerequisites String[]
  tags          String[]
  modules       Module[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  forumThreads  ForumThread[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([disciplineId])
}

model Module {
  id         String   @id @default(cuid())
  parcoursId String
  parcours   Parcours @relation(fields: [parcoursId], references: [id], onDelete: Cascade)
  index      Int
  title      String
  lessons    Lesson[]

  @@unique([parcoursId, index])
}

model Lesson {
  id          String           @id @default(cuid())
  moduleId    String
  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  index       Int
  title       String
  type        LessonType
  durationMin Int
  content     Json
  progress    LessonProgress[]
  submissions Submission[]

  @@unique([moduleId, index])
}

model Cohort {
  id          String       @id @default(cuid())
  name        String
  tutorId     String?
  tutor       User?        @relation("TutorCohorts", fields: [tutorId], references: [id])
  enrollments Enrollment[]
  submissions Submission[]
  createdAt   DateTime     @default(now())

  @@index([tutorId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcoursId String
  parcours   Parcours @relation(fields: [parcoursId], references: [id], onDelete: Cascade)
  cohortId   String?
  cohort     Cohort?  @relation(fields: [cohortId], references: [id])
  tutorName  String?
  progress   Int      @default(0)
  enrolledAt DateTime @default(now())

  @@unique([userId, parcoursId])
  @@index([parcoursId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([userId, lessonId])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  icon        String
  rarity      String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Certificate {
  id         String   @id @default(cuid())
  code       String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcoursId String
  parcours   Parcours @relation(fields: [parcoursId], references: [id])
  score      Int
  pdfUrl     String? // URL stable du PDF (Vercel Blob), généré à la demande
  issuedAt   DateTime @default(now())

  @@unique([userId, parcoursId])
}

enum SubmissionStatus {
  PENDING
  GRADED
}

// Réponse à un exercice à correction manuelle (réponse longue, devoir…).
model Submission {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("UserSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  lessonId   String
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exerciceId String // id de l'exercice dans le contenu du quiz
  prompt     String // copie de l'énoncé au moment de la soumission
  answer     String           @db.Text
  status     SubmissionStatus @default(PENDING)
  score      Int? // note attribuée (sur maxScore)
  maxScore   Int              @default(20)
  feedback   String?          @db.Text
  cohortId   String?
  cohort     Cohort?          @relation(fields: [cohortId], references: [id])
  gradedById String?
  gradedBy   User?            @relation("GradedSubmissions", fields: [gradedById], references: [id])
  gradedAt   DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, lessonId, exerciceId])
  @@index([status])
  @@index([cohortId])
  @@index([lessonId])
}

// Forums (§14.2) : discussions par parcours ou générales + réponses.
model ForumThread {
  id         String      @id @default(cuid())
  title      String
  body       String      @db.Text
  authorId   String
  author     User        @relation("ForumThreads", fields: [authorId], references: [id], onDelete: Cascade)
  parcoursId String? // null = forum général
  parcours   Parcours?   @relation(fields: [parcoursId], references: [id])
  pinned     Boolean     @default(false)
  locked     Boolean     @default(false)
  deletedAt  DateTime?
  posts      ForumPost[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([parcoursId])
  @@index([createdAt])
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation("ForumPosts", fields: [authorId], references: [id], onDelete: Cascade)
  body      String      @db.Text
  deletedAt DateTime?
  createdAt DateTime    @default(now())

  @@index([threadId])
}

// Messagerie privée (§14.3) : conversations 1-à-1 + messages.
model Conversation {
  id            String                    @id @default(cuid())
  participants  ConversationParticipant[]
  messages      Message[]
  lastMessageAt DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// Médiathèque centralisée (§17.5) : fichiers téléversés réutilisables.
model Media {
  id           String   @id @default(cuid())
  url          String
  filename     String
  contentType  String
  size         Int
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// Paramètres système (§17.6) : stockage clé-valeur.
model Setting {
  key   String @id
  value String @db.Text
}

model Actualite {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  category    String
  publishedAt DateTime
  readingTime Int
}

model Partenaire {
  id      String @id @default(cuid())
  acronym String @unique
  name    String
  role    String
  order   Int    @default(0)
}

model Temoignage {
  id       String @id @default(cuid())
  name     String
  role     String
  college  String
  quote    String @db.Text
  initials String
  order    Int    @default(0)
}
