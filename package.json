{
  "name": "dhfc-ebis-vitrine",
  "version": "1.0.0",
  "description": "Vitrine institutionnelle DHFC-EBiS — Dispositif Hybride de Formation Continue des Enseignants Bivalents de Sciences",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
